# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# Build artifacts (too large for GitHub — never commit)
*.aab
*.apk
*.ipa
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
service-account-key.json
functions/service-account-key.json

# Local state file written by functions/test-watchdog.js
functions/.test-watchdog-state.json

# Firebase Functions env (holds Razorpay key secret — must NEVER be committed)
functions/.env
functions/.env.*

# Android release signing — keystore + passwords. The keystore is the
# single source of truth for app identity on Play Store; losing it
# means you can never push an update under the same app ID again.
# Back it up somewhere safe (1Password / GitHub Actions secret /
# secure offline storage) and NEVER commit it.
android/key.properties
android/app/upload-keystore.jks
android/app/*.jks
android/app/*.keystore
