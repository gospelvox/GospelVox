<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Runtime permissions required across the app.

        INTERNET / ACCESS_NETWORK_STATE are required in the MAIN manifest
        for release builds — the debug manifest only applies when running
        via `flutter run`. Without these a release APK silently fails on
        every Firebase / Razorpay / HTTP call.

        Media + camera are required by image_picker (priest registration
        photo, user profile avatar). Android 13+ replaces the legacy
        READ_EXTERNAL_STORAGE with the granular READ_MEDIA_IMAGES.

        Voice call permissions (RECORD_AUDIO, MODIFY_AUDIO_SETTINGS,
        BLUETOOTH_CONNECT) are required by agora_rtc_engine. Without
        RECORD_AUDIO the call SDK fails to initialise the mic.

        POST_NOTIFICATIONS is required by OneSignal on Android 13+
        (API 33). Without it the user never sees a system prompt and
        push delivery is permanently blocked.

        WAKE_LOCK keeps the CPU running during a live voice session so
        the billing heartbeat timers don't drift when the screen goes
        off mid-call.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- image_picker -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Android 12 and below still use the legacy storage permission. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- agora_rtc_engine -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <!-- Legacy BLUETOOTH permission for Android 7-11 (API 24-30).
         Android 12+ replaced it with the runtime BLUETOOTH_CONNECT
         below, but our minSdk is 24 — without this, Agora can't
         route audio to BT headsets / AirPods / car systems on the
         legacy half of the install base. The maxSdkVersion ensures
         it isn't requested on devices that already use the new
         runtime model. -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>

    <!-- onesignal_flutter / firebase_messaging (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Keep CPU awake during live sessions so timers don't drift. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Foreground service that keeps a voice call alive when the
         user backgrounds the app or locks the screen. Without this,
         aggressive OEM battery managers (Xiaomi/Oppo/Samsung) kill
         the process within seconds of backgrounding and the call
         drops. The MICROPHONE-typed FGS is required on Android 14+
         when the service captures audio. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>

    <!-- Optional features — let Play Store filter correctly instead of
         rejecting devices without a camera. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false"/>

    <application
        android:label="GospelVox"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Disable Impeller on Android. Razorpay's checkout activity
             composites a WebView on top of the Flutter surface; with
             Impeller (the new Vulkan/GL renderer) that overlay shows
             up with mangled text and misaligned images on several
             OEM skins (notably Samsung One UI). Falling back to Skia
             fixes the checkout sheet rendering at the cost of no
             practical perf difference on this screen. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

        <!-- Voice call foreground service. Started by VoiceCallCubit
             via a MethodChannel into MainActivity, stopped when the
             call ends. The "microphone" foregroundServiceType is
             mandatory on Android 14+ when the service captures audio;
             starting without it throws SecurityException at runtime. -->
        <service
            android:name=".CallForegroundService"
            android:foregroundServiceType="microphone"
            android:exported="false" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
